[
  {
    "start_sec": 0.0,
    "end_sec": 1.66,
    "text": "an urgency that I do."
  },
  {
    "start_sec": 1.66,
    "end_sec": 3.9,
    "text": "If you feel the same passion that I do,"
  },
  {
    "start_sec": 3.9,
    "end_sec": 6.66,
    "text": "if you feel the same hopefulness that I do,"
  },
  {
    "start_sec": 6.66,
    "end_sec": 8.7,
    "text": "if we do what we must do,"
  },
  {
    "start_sec": 8.7,
    "end_sec": 12.74,
    "text": "then I have no doubt that all across the country,"
  },
  {
    "start_sec": 12.74,
    "end_sec": 14.38,
    "text": "from Florida to Oregon,"
  },
  {
    "start_sec": 14.38,
    "end_sec": 16.82,
    "text": "from Washington to Maine,"
  },
  {
    "start_sec": 16.82,
    "end_sec": 19.34,
    "text": "the people will rise up in November,"
  },
  {
    "start_sec": 19.34,
    "end_sec": 21.94,
    "text": "and John Kerry will be sworn in as President,"
  },
  {
    "start_sec": 21.94,
    "end_sec": 25.02,
    "text": "and John Edwards will be sworn in as Vice President,"
  },
  {
    "start_sec": 25.02,
    "end_sec": 27.46,
    "text": "and this country will reclaim its promise"
  },
  {
    "start_sec": 27.46,
    "end_sec": 29.72,
    "text": "and out of this long political darkness"
  },
  {
    "start_sec": 29.72,
    "end_sec": 31.04,
    "text": "a brighter day will come."
  },
  {
    "start_sec": 31.04,
    "end_sec": 32.24,
    "text": "Thank you very much, everybody."
  },
  {
    "start_sec": 32.24,
    "end_sec": 33.68,
    "text": "God bless you."
  },
  {
    "start_sec": 33.68,
    "end_sec": 34.68,
    "text": "Thank you."
  }
]